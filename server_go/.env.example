# Copy this file to server_go/.env and fill in real values.
# The .env file is gitignored — never commit real credentials.
DATABASE_URL=postgres://your_user:your_password@localhost:5432/whoknows?sslmode=disable
POSTGRES_DB=whoknows
POSTGRES_PASSWORD=your_password
POSTGRES_USER=your_user
WHOKNOWS_ADDR=0.0.0.0
WHOKNOWS_PORT=8080
