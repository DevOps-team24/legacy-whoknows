# Example env file for production. The real .env on the droplet is generated
# by Ansible from env.j2, which reads POSTGRES_* from env vars (GitHub Secrets
# in CI, or exported locally before running ansible-playbook).
POSTGRES_USER=your_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=whoknows
DATABASE_URL=postgres://your_user:your_password@postgres:5432/whoknows?sslmode=disable
WHOKNOWS_PORT=8080
WHOKNOWS_ADDR=0.0.0.0
